<Window
    x:Class="StageManager.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:StageManager"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:tb="http://www.hardcodet.net/taskbar"
    mc:Ignorable="d"
    AllowsTransparency="True"
    ShowInTaskbar="False"
    Topmost="False"
    WindowStyle="None"
    Title="MainWindow"
    Height="450"
    Width="280"
    ShowActivated="False"
    Background="Transparent"
    Name="thisWindow">
    <Window.Resources>
        <BooleanToVisibilityConverter
            x:Key="BoolToVisibility" />
        <Style
            x:Key="SceneOpacity"
            TargetType="{x:Type StackPanel}">
            <Setter
                Property="Opacity"
                Value="0.8" />
            <Style.Triggers>
                <Trigger
                    Property="IsMouseOver"
                    Value="true">
                    <Setter
                        Property="Opacity"
                        Value="1" />
                </Trigger>
                <Trigger
                    Property="IsMouseOver"
                    Value="false">
                    <Setter
                        Property="Opacity"
                        Value="0.8" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <StackPanel
        VerticalAlignment="Center">
        <ItemsControl
            Name="scenesControl"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Padding="12, 12, 0, 12"
            ItemsSource="{Binding Scenes}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid
                        x:Name="sceneRoot"
                        Visibility="{Binding Visibility}">
                        <StackPanel
                            Orientation="Vertical"
                            Style="{StaticResource SceneOpacity}">
                            <i:Interaction.Triggers>
                                <i:EventTrigger
                                    EventName="MouseLeftButtonUp">
                                    <i:InvokeCommandAction
                                        Command="{Binding SwitchSceneCommand, Mode=OneTime, Source={x:Reference thisWindow}}"
                                        CommandParameter="{Binding .}" />
                                </i:EventTrigger>
                            </i:Interaction.Triggers>
                            <!-- Windows -->
                            <ContentControl
                                x:Name="previewItems"
                                Content="{Binding PrimaryDisplayWindow}">
                                <ContentControl.Style>
                                    <Style
                                        TargetType="{x:Type ContentControl}">
                                        <Setter
                                            Property="Visibility"
                                            Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger
                                                Binding="{Binding HasDisplayWindows}"
                                                Value="False">
                                                <Setter
                                                    Property="Visibility"
                                                    Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ContentControl.Style>
                                <ContentControl.ContentTemplate>
                                    <DataTemplate>
                                        <Grid
                                            x:Name="previewCard"
                                            Width="164"
                                            Height="97"
                                            ClipToBounds="True"
                                            Panel.ZIndex="1"
                                            RenderTransformOrigin="0.5,0.58">
                                            <Grid.RenderTransform>
                                                <ScaleTransform
                                                    x:Name="previewScale"
                                                    ScaleX="1"
                                                    ScaleY="1" />
                                            </Grid.RenderTransform>
                                            <Border
                                                x:Name="stackLayer3"
                                                Width="154"
                                                Height="87"
                                                Margin="0,0,0,0"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Top"
                                                Background="#CFFFFFFF"
                                                BorderBrush="#AAFFFFFF"
                                                BorderThickness="1"
                                                Visibility="Collapsed" />
                                            <Border
                                                x:Name="stackLayer2"
                                                Width="154"
                                                Height="87"
                                                Margin="5,5,0,0"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Top"
                                                Background="#D8FFFFFF"
                                                BorderBrush="#AAFFFFFF"
                                                BorderThickness="1"
                                                Visibility="Collapsed" />
                                            <local:DwmThumbnail
                                                x:Name="livePreview"
                                                PreviewHandle="{Binding Handle}"
                                                Width="154"
                                                Height="87"
                                                Margin="10,10,0,0"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Top" />
                                            <Border
                                                x:Name="iconPreview"
                                                Width="154"
                                                Height="87"
                                                Margin="10,10,0,0"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Top"
                                                Visibility="Collapsed"
                                                Background="#D8FFFFFF"
                                                BorderBrush="#AAFFFFFF"
                                                BorderThickness="1">
                                                <Image
                                                    Width="44"
                                                    Height="44"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Source="{Binding Icon}"
                                                    Stretch="Uniform" />
                                            </Border>
                                        </Grid>
                                        <DataTemplate.Triggers>
                                            <EventTrigger
                                                RoutedEvent="MouseEnter">
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation
                                                            Storyboard.TargetName="previewScale"
                                                            Storyboard.TargetProperty="ScaleX"
                                                            To="1.035"
                                                            Duration="0:0:0.14" />
                                                        <DoubleAnimation
                                                            Storyboard.TargetName="previewScale"
                                                            Storyboard.TargetProperty="ScaleY"
                                                            To="1.035"
                                                            Duration="0:0:0.14" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                            <EventTrigger
                                                RoutedEvent="MouseLeave">
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation
                                                            Storyboard.TargetName="previewScale"
                                                            Storyboard.TargetProperty="ScaleX"
                                                            To="1"
                                                            Duration="0:0:0.16" />
                                                        <DoubleAnimation
                                                            Storyboard.TargetName="previewScale"
                                                            Storyboard.TargetProperty="ScaleY"
                                                            To="1"
                                                            Duration="0:0:0.16" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                            <DataTrigger
                                                Binding="{Binding HasVisibleOwnedPopup}"
                                                Value="True">
                                                <Setter
                                                    TargetName="livePreview"
                                                    Property="Visibility"
                                                    Value="Collapsed" />
                                                <Setter
                                                    TargetName="iconPreview"
                                                    Property="Visibility"
                                                    Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger
                                                Binding="{Binding DataContext.StackDepth, RelativeSource={RelativeSource AncestorType=ContentControl}}"
                                                Value="2">
                                                <Setter
                                                    TargetName="stackLayer2"
                                                    Property="Visibility"
                                                    Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger
                                                Binding="{Binding DataContext.StackDepth, RelativeSource={RelativeSource AncestorType=ContentControl}}"
                                                Value="3">
                                                <Setter
                                                    TargetName="stackLayer2"
                                                    Property="Visibility"
                                                    Value="Visible" />
                                                <Setter
                                                    TargetName="stackLayer3"
                                                    Property="Visibility"
                                                    Value="Visible" />
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ContentControl.ContentTemplate>
                            </ContentControl>
                            <!-- Icons -->
                            <StackPanel
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                MinHeight="44"
                                Margin="0,12,0,30"
                                Panel.ZIndex="5">
                                <ItemsControl
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    ItemsSource="{Binding DisplayWindows}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel
                                                MaxWidth="132"
                                                Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border
                                                Margin="1">
                                                <Border.Effect>
                                                    <DropShadowEffect
                                                        BlurRadius="20" />
                                                </Border.Effect>
                                                <Button
                                                    Width="34"
                                                    Height="34"
                                                    Padding="0"
                                                    Background="Transparent"
                                                    BorderBrush="Transparent"
                                                    Command="{Binding ActivateAppIconCommand, Mode=OneTime, Source={x:Reference thisWindow}}"
                                                    CommandParameter="{Binding .}">
                                                    <Image
                                                        x:Name="stageIconImage"
                                                        Margin="0, 0, 0, 0"
                                                        Width="30"
                                                        Height="30"
                                                        RenderTransformOrigin="0.5,0.5"
                                                        Stretch="Uniform"
                                                        Source="{Binding Icon}">
                                                        <Image.RenderTransform>
                                                            <ScaleTransform
                                                                x:Name="stageIconScale"
                                                                ScaleX="1"
                                                                ScaleY="1" />
                                                        </Image.RenderTransform>
                                                    </Image>
                                                </Button>
                                            </Border>
                                            <DataTemplate.Triggers>
                                                <EventTrigger
                                                    RoutedEvent="MouseEnter">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation
                                                                Storyboard.TargetName="stageIconScale"
                                                                Storyboard.TargetProperty="ScaleX"
                                                            To="1.1"
                                                                Duration="0:0:0.12" />
                                                            <DoubleAnimation
                                                                Storyboard.TargetName="stageIconScale"
                                                                Storyboard.TargetProperty="ScaleY"
                                                            To="1.1"
                                                                Duration="0:0:0.12" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                                <EventTrigger
                                                    RoutedEvent="MouseLeave">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation
                                                                Storyboard.TargetName="stageIconScale"
                                                                Storyboard.TargetProperty="ScaleX"
                                                                To="1"
                                                                Duration="0:0:0.14" />
                                                            <DoubleAnimation
                                                                Storyboard.TargetName="stageIconScale"
                                                                Storyboard.TargetProperty="ScaleY"
                                                                To="1"
                                                                Duration="0:0:0.14" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Button
                                    Width="26"
                                    Height="24"
                                    Margin="6,0,0,0"
                                    Padding="0"
                                    VerticalAlignment="Center"
                                    Background="#DDF6F8FA"
                                    BorderBrush="#99FFFFFF"
                                    Click="WindowPickerButton_Click"
                                    Visibility="{Binding HasMultipleWindows, Converter={StaticResource BoolToVisibility}}">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="18"
                                        FontWeight="SemiBold"
                                        Foreground="#333333"
                                        LineHeight="18"
                                        Text="+" />
                                </Button>
                            </StackPanel>
                        </StackPanel>
                        <Popup
                            AllowsTransparency="False"
                            HorizontalOffset="24"
                            IsOpen="{Binding IsWindowPickerOpen, Mode=TwoWay}"
                            Placement="Right"
                            PlacementTarget="{Binding ElementName=sceneRoot}"
                            StaysOpen="False">
                            <Border
                                MaxWidth="540"
                                Padding="16,14"
                                Background="#F2FFFFFF"
                                BorderBrush="#55FFFFFF"
                                BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect
                                        BlurRadius="24"
                                        Opacity="0.35" />
                                </Border.Effect>
                                <ItemsControl
                                    ItemsSource="{Binding DisplayWindows}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel
                                                Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button
                                                Width="162"
                                                Margin="4"
                                                Padding="4"
                                                Background="Transparent"
                                                BorderBrush="Transparent"
                                                Command="{Binding ActivateWindowCommand, Mode=OneTime, Source={x:Reference thisWindow}}"
                                                CommandParameter="{Binding .}">
                                                <StackPanel>
                                                    <Grid
                                                        x:Name="pickerPreviewCard"
                                                        Width="154"
                                                        Height="92"
                                                        ClipToBounds="True"
                                                        Panel.ZIndex="1"
                                                        RenderTransformOrigin="0.5,0.58">
                                                        <Grid.RenderTransform>
                                                            <ScaleTransform
                                                                x:Name="pickerPreviewScale"
                                                                ScaleX="1"
                                                                ScaleY="1" />
                                                        </Grid.RenderTransform>
                                                        <local:DwmThumbnail
                                                            x:Name="pickerLivePreview"
                                                            Width="154"
                                                            Height="92"
                                                            PreviewHandle="{Binding Handle}" />
                                                        <Border
                                                            x:Name="pickerIconPreview"
                                                            Visibility="Collapsed"
                                                            Background="#E8FFFFFF"
                                                            BorderBrush="#AAFFFFFF"
                                                            BorderThickness="1">
                                                            <Image
                                                                Width="44"
                                                                Height="44"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                Source="{Binding Icon}"
                                                                Stretch="Uniform" />
                                                        </Border>
                                                    </Grid>
                                                    <DockPanel
                                                        Margin="0,6,0,0"
                                                        LastChildFill="True">
                                                        <Image
                                                            x:Name="pickerLabelIcon"
                                                            Width="24"
                                                            Height="24"
                                                            Margin="0,0,6,0"
                                                            RenderTransformOrigin="0.5,0.5"
                                                            Source="{Binding Icon}"
                                                            Stretch="Uniform">
                                                            <Image.RenderTransform>
                                                                <ScaleTransform
                                                                    x:Name="pickerLabelIconScale"
                                                                    ScaleX="1"
                                                                    ScaleY="1" />
                                                            </Image.RenderTransform>
                                                        </Image>
                                                        <TextBlock
                                                            VerticalAlignment="Center"
                                                            FontSize="12"
                                                            Foreground="#222222"
                                                            Text="{Binding Title}"
                                                            TextTrimming="CharacterEllipsis" />
                                                    </DockPanel>
                                                </StackPanel>
                                            </Button>
                                            <DataTemplate.Triggers>
                                                <EventTrigger
                                                    RoutedEvent="MouseEnter">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation
                                                                Storyboard.TargetName="pickerPreviewScale"
                                                                Storyboard.TargetProperty="ScaleX"
                                                                To="1.025"
                                                                Duration="0:0:0.14" />
                                                            <DoubleAnimation
                                                                Storyboard.TargetName="pickerPreviewScale"
                                                                Storyboard.TargetProperty="ScaleY"
                                                                To="1.025"
                                                                Duration="0:0:0.14" />
                                                            <DoubleAnimation
                                                                Storyboard.TargetName="pickerLabelIconScale"
                                                                Storyboard.TargetProperty="ScaleX"
                                                                To="1.12"
                                                                Duration="0:0:0.12" />
                                                            <DoubleAnimation
                                                                Storyboard.TargetName="pickerLabelIconScale"
                                                                Storyboard.TargetProperty="ScaleY"
                                                                To="1.12"
                                                                Duration="0:0:0.12" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                                <EventTrigger
                                                    RoutedEvent="MouseLeave">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation
                                                                Storyboard.TargetName="pickerPreviewScale"
                                                                Storyboard.TargetProperty="ScaleX"
                                                                To="1"
                                                                Duration="0:0:0.16" />
                                                            <DoubleAnimation
                                                                Storyboard.TargetName="pickerPreviewScale"
                                                                Storyboard.TargetProperty="ScaleY"
                                                                To="1"
                                                                Duration="0:0:0.16" />
                                                            <DoubleAnimation
                                                                Storyboard.TargetName="pickerLabelIconScale"
                                                                Storyboard.TargetProperty="ScaleX"
                                                                To="1"
                                                                Duration="0:0:0.14" />
                                                            <DoubleAnimation
                                                                Storyboard.TargetName="pickerLabelIconScale"
                                                                Storyboard.TargetProperty="ScaleY"
                                                                To="1"
                                                                Duration="0:0:0.14" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                                <DataTrigger
                                                    Binding="{Binding HasVisibleOwnedPopup}"
                                                    Value="True">
                                                    <Setter
                                                        TargetName="pickerLivePreview"
                                                        Property="Visibility"
                                                        Value="Collapsed" />
                                                    <Setter
                                                        TargetName="pickerIconPreview"
                                                        Property="Visibility"
                                                        Value="Visible" />
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>
                        </Popup>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        <tb:TaskbarIcon
            x:Name="trayIcon"
            Visibility="Visible"
            ToolTipText="{Binding StageManagerStatus}"
            IconSource="StageManager.ico"
            MenuActivation="LeftOrRightClick">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu
                    Opened="ContextMenu_Opened"
                    Closed="ContextMenu_Closed">
                    <MenuItem
                        Header="Stage Manager on"
                        IsCheckable="True"
                        IsChecked="{Binding IsStageManagerEnabled, Mode=TwoWay}" />
                    <Separator />
                    <MenuItem
                        Header="Start with Windows"
                        IsCheckable="True"
                        IsChecked="{Binding StartsWithWindows}" />
                    <MenuItem
                        Header="Auto-hide Stage Manager icons"
                        IsCheckable="True"
                        IsChecked="{Binding AutoHideStageManagerIcons, Mode=TwoWay}" />
                    <MenuItem
                        Header="Settings"
                        Click="MenuItem_Settings_Click" />
                    <MenuItem
                        Header="Project page"
                        Click="MenuItem_ProjectPage_Click" />
                    <Separator />
                    <MenuItem
                        Header="Quit"
                        Click="MenuItem_Quit_Click" />
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>
    </StackPanel>
</Window>
