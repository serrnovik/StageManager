<Window
    x:Class="StageManager.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:StageManager"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:tb="http://www.hardcodet.net/taskbar"
    mc:Ignorable="d"
    AllowsTransparency="True"
    ShowInTaskbar="False"
    Topmost="False"
    WindowStyle="None"
    Title="MainWindow"
    Height="450"
    Width="280"
    ShowActivated="False"
    Background="Transparent"
    Name="thisWindow">
    <Window.Resources>
        <BooleanToVisibilityConverter
            x:Key="BoolToVisibility" />
        <Style
            x:Key="SceneOpacity"
            TargetType="{x:Type StackPanel}">
            <Setter
                Property="Opacity"
                Value="0.8" />
            <Style.Triggers>
                <Trigger
                    Property="IsMouseOver"
                    Value="true">
                    <Setter
                        Property="Opacity"
                        Value="1" />
                </Trigger>
                <Trigger
                    Property="IsMouseOver"
                    Value="false">
                    <Setter
                        Property="Opacity"
                        Value="0.8" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <StackPanel
        VerticalAlignment="Center">
        <ItemsControl
            Name="scenesControl"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Padding="12, 0, 0, 0"
            ItemsSource="{Binding Scenes}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid
                        x:Name="sceneRoot"
                        Visibility="{Binding Visibility}">
                        <StackPanel
                            Orientation="Vertical"
                            Style="{StaticResource SceneOpacity}">
                            <i:Interaction.Triggers>
                                <i:EventTrigger
                                    EventName="MouseLeftButtonUp">
                                    <i:InvokeCommandAction
                                        Command="{Binding SwitchSceneCommand, Mode=OneTime, Source={x:Reference thisWindow}}"
                                        CommandParameter="{Binding .}" />
                                </i:EventTrigger>
                            </i:Interaction.Triggers>
                            <!-- Windows -->
                            <ItemsControl
                                ItemsSource="{Binding Windows}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Grid
                                            Margin="0,0,0,0"></Grid>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <local:DwmThumbnail
                                            PreviewHandle="{Binding Handle}"
                                            MinHeight="100"
                                            MinWidth="150"
                                            Margin="0, 0, 0, 0" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <!-- Icons -->
                            <StackPanel
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,4,0,24">
                                <ItemsControl
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    ItemsSource="{Binding Windows}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel
                                                Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border>
                                                <Border.Effect>
                                                    <DropShadowEffect
                                                        BlurRadius="20" />
                                                </Border.Effect>
                                                <Image
                                                    Margin="0, 0, 0, 0"
                                                    Height="30"
                                                    Source="{Binding Icon}" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Button
                                    Width="22"
                                    Height="22"
                                    Margin="6,0,0,0"
                                    Padding="0"
                                    VerticalAlignment="Center"
                                    Background="#CCFFFFFF"
                                    BorderBrush="#66FFFFFF"
                                    Click="WindowPickerButton_Click"
                                    Visibility="{Binding HasMultipleWindows, Converter={StaticResource BoolToVisibility}}">
                                    <Path
                                        Data="M 5 14 L 11 8 L 17 14"
                                        Stroke="#333333"
                                        StrokeThickness="2.2"
                                        StrokeStartLineCap="Round"
                                        StrokeEndLineCap="Round" />
                                </Button>
                            </StackPanel>
                        </StackPanel>
                        <Popup
                            AllowsTransparency="True"
                            IsOpen="{Binding IsWindowPickerOpen, Mode=TwoWay}"
                            Placement="Right"
                            PlacementTarget="{Binding ElementName=sceneRoot}"
                            StaysOpen="False">
                            <Border
                                MaxWidth="540"
                                Padding="12"
                                Background="#F2FFFFFF"
                                BorderBrush="#55FFFFFF"
                                BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect
                                        BlurRadius="24"
                                        Opacity="0.35" />
                                </Border.Effect>
                                <ItemsControl
                                    ItemsSource="{Binding Windows}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel
                                                Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button
                                                Width="228"
                                                Margin="4"
                                                Padding="4"
                                                Background="Transparent"
                                                BorderBrush="Transparent"
                                                Command="{Binding ActivateWindowCommand, Mode=OneTime, Source={x:Reference thisWindow}}"
                                                CommandParameter="{Binding .}">
                                                <StackPanel>
                                                    <local:DwmThumbnail
                                                        Width="220"
                                                        Height="132"
                                                        PreviewHandle="{Binding Handle}" />
                                                    <DockPanel
                                                        Margin="0,6,0,0"
                                                        LastChildFill="True">
                                                        <Image
                                                            Width="24"
                                                            Height="24"
                                                            Margin="0,0,6,0"
                                                            Source="{Binding Icon}" />
                                                        <TextBlock
                                                            VerticalAlignment="Center"
                                                            FontSize="12"
                                                            Foreground="#222222"
                                                            Text="{Binding Title}"
                                                            TextTrimming="CharacterEllipsis" />
                                                    </DockPanel>
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>
                        </Popup>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        <tb:TaskbarIcon
            x:Name="trayIcon"
            Visibility="Visible"
            ToolTipText="{Binding StageManagerStatus}"
            IconSource="StageManager.ico"
            MenuActivation="LeftOrRightClick">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu
                    Opened="ContextMenu_Opened"
                    Closed="ContextMenu_Closed">
                    <MenuItem
                        Header="Stage Manager on"
                        IsCheckable="True"
                        IsChecked="{Binding IsStageManagerEnabled, Mode=TwoWay}" />
                    <Separator />
                    <MenuItem
                        Header="Start with Windows"
                        IsCheckable="True"
                        IsChecked="{Binding StartsWithWindows}" />
                    <MenuItem
                        Header="Project page"
                        Click="MenuItem_ProjectPage_Click" />
                    <Separator />
                    <MenuItem
                        Header="Quit"
                        Click="MenuItem_Quit_Click" />
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>
    </StackPanel>
</Window>
