<Window
    x:Class="StageManager.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="StageManager Settings"
    Width="460"
    Height="340"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style
            TargetType="{x:Type TextBox}">
            <Setter
                Property="Height"
                Value="30" />
            <Setter
                Property="Padding"
                Value="8,4" />
            <Setter
                Property="VerticalContentAlignment"
                Value="Center" />
            <Setter
                Property="IsReadOnly"
                Value="True" />
            <Setter
                Property="Cursor"
                Value="Hand" />
        </Style>
        <Style
            TargetType="{x:Type Button}">
            <Setter
                Property="MinWidth"
                Value="82" />
            <Setter
                Property="Height"
                Value="30" />
            <Setter
                Property="Padding"
                Value="12,4" />
        </Style>
    </Window.Resources>
    <Grid
        Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition
                Height="Auto" />
            <RowDefinition
                Height="*" />
            <RowDefinition
                Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock
                FontSize="18"
                FontWeight="SemiBold"
                Text="Settings" />
            <TextBlock
                Margin="0,4,0,16"
                Foreground="#666666"
                Text="Click a shortcut field, then press the new key combination." />
        </StackPanel>

        <Grid
            Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition
                    Width="190" />
                <ColumnDefinition
                    Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition
                    Height="Auto" />
                <RowDefinition
                    Height="Auto" />
                <RowDefinition
                    Height="Auto" />
                <RowDefinition
                    Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock
                Grid.Row="0"
                VerticalAlignment="Center"
                Text="Turn on/off" />
            <TextBox
                x:Name="ToggleStageManagerShortcutBox"
                Grid.Row="0"
                Grid.Column="1"
                PreviewKeyDown="ShortcutBox_PreviewKeyDown"
                GotKeyboardFocus="ShortcutBox_GotKeyboardFocus" />

            <TextBlock
                Grid.Row="1"
                Margin="0,14,0,0"
                VerticalAlignment="Center"
                Text="Auto-hide on/off" />
            <TextBox
                x:Name="ToggleAutoHideShortcutBox"
                Grid.Row="1"
                Grid.Column="1"
                Margin="0,14,0,0"
                PreviewKeyDown="ShortcutBox_PreviewKeyDown"
                GotKeyboardFocus="ShortcutBox_GotKeyboardFocus" />

            <TextBlock
                Grid.Row="2"
                Margin="0,14,0,0"
                VerticalAlignment="Center"
                Text="Show hidden items" />
            <TextBox
                x:Name="RevealStageManagerShortcutBox"
                Grid.Row="2"
                Grid.Column="1"
                Margin="0,14,0,0"
                PreviewKeyDown="ShortcutBox_PreviewKeyDown"
                GotKeyboardFocus="ShortcutBox_GotKeyboardFocus" />

            <CheckBox
                Grid.Row="3"
                Grid.ColumnSpan="2"
                x:Name="AutoHideCheckBox"
                Margin="0,20,0,0"
                Content="Auto-hide Stage Manager icons" />
        </Grid>

        <DockPanel
            Grid.Row="2"
            LastChildFill="False">
            <Button
                DockPanel.Dock="Left"
                Content="Defaults"
                Click="DefaultsButton_Click" />
            <StackPanel
                DockPanel.Dock="Right"
                Orientation="Horizontal">
                <Button
                    Margin="0,0,8,0"
                    Content="Cancel"
                    Click="CancelButton_Click" />
                <Button
                    Content="Save"
                    IsDefault="True"
                    Click="SaveButton_Click" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
